# Copy this file to .env and fill in values marked as REQUIRED.
# Everything else already has working defaults for local e2e.

# ── LLM Provider (REQUIRED for AI opinion generation) ────────────────────────
# Options: openai | anthropic | google | sarvam
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4

# ── Sarvam AI (REQUIRED for document processing) ─────────────────────────────
SARVAM_API_KEY=
SARVAM_API_BASE_URL=https://api.sarvam.ai
SARVAM_OCR_CONFIDENCE_THRESHOLD=0.7

# ── CORS (optional override) ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost,http://localhost:80

# ── S3 storage (only needed if you switch STORAGE_DRIVER=s3) ─────────────────
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_BUCKET=legalops-documents
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true

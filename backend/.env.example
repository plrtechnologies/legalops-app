# App
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legalops
DB_USER=legalops
DB_PASSWORD=Legalops@123
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Keycloak (HLD aligned)
KEYCLOAK_URL=http://localhost:8080/auth
KEYCLOAK_REALM=legal-opinion-saas
KEYCLOAK_CLIENT_ID=legal-opinion-api
KEYCLOAK_FRONTEND_CLIENT_ID=legal-opinion-web

# Storage driver: local | nfs | s3
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=/tmp/legalops-documents
NFS_STORAGE_PATH=/mnt/nfs/legalops-documents
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=legalops-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Sarvam AI
SARVAM_API_KEY=
SARVAM_API_BASE_URL=https://api.sarvam.ai
SARVAM_OCR_CONFIDENCE_THRESHOLD=0.7

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:80,http://legalops.local
